# ---- Supabase (required) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only — never expose to the client

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # e.g. https://classact.college in prod

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM="ClassAct <noreply@classact.college>"

# ---- Canvas roster sync (optional) ----
CANVAS_BASE_URL=https://clemson.instructure.com   # your school's Canvas URL, no trailing slash
CANVAS_API_TOKEN=                                 # server-only personal access token; treat like a password

# ---- AI question generation (OpenRouter) ----
OPENROUTER_API_KEY=                               # server-only; from openrouter.ai/keys — treat like a password
OPENROUTER_MODEL=                                 # optional; defaults to anthropic/claude-sonnet-5

# ---- Analytics (PostHog) ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Error tracking (Sentry) ----
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                  # optional, for build-time source maps
